# Required secrets
POLYGON_WALLET_PRIVATE_KEY=your_polygon_wallet_private_key_here
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tradebot

# Trading parameters (pre-registered -- do not tune on historical market data)
PAPER_TRADING=true
KELLY_FRACTION=0.08
MAX_TRADE_USD=3.0
MAX_BANKROLL_PCT=0.03
MAX_PORTFOLIO_EXPOSURE=0.20
HIGH_REGIME_EDGE_THRESHOLD=0.08
MEDIUM_REGIME_EDGE_THRESHOLD=0.12
MIN_HOURS_TO_RESOLUTION=2
MIN_MARKET_VOLUME=2000

# API URLs (defaults are production endpoints)
# POLYMARKET_API_URL=https://clob.polymarket.com
# POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
